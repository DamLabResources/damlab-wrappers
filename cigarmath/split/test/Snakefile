    params:
        split_by="flag",
        flag_categories={"suppl": {"is_supplementary": True}, "primary": {"is_supplementary": False}},
        output_format="fastq",
        top_n=1,
        sample_name="test",
    wrapper:
        f"file:{TEST_ROOT_cigarmath__SPLIT.parent}"


# ---------------------------------------------------------------------------
# Split by CSV — toy name-sorted SAM, FASTA output
# ---------------------------------------------------------------------------
rule test_split__toy_csv:
    input:
        TEST_ROOT_cigarmath__SPLIT / "test_output/toy_namesorted.bam",
        csv_file=TEST_ROOT_cigarmath__SPLIT / "toy_csv.csv",
    output:
        directory(TEST_ROOT_cigarmath__SPLIT / "test_output/toy_csv_fasta/"),
        TEST_ROOT_cigarmath__SPLIT / "test_output/toy_csv_fasta_summary.yaml",
    params:
        split_by="csv",
        output_format="fasta",
        sample_name="toy",
    wrapper:
        f"file:{TEST_ROOT_cigarmath__SPLIT.parent}"


# ---------------------------------------------------------------------------
# Split by HP tag + required_reference_overlap — toy name-sorted SAM, BAM output
# ---------------------------------------------------------------------------
rule test_split__toy_tag:
    input:
        TEST_ROOT_cigarmath__SPLIT / "test_output/toy_namesorted.bam",
    output:
        directory(TEST_ROOT_cigarmath__SPLIT / "test_output/toy_tag_bam/"),
        TEST_ROOT_cigarmath__SPLIT / "test_output/toy_tag_bam_summary.yaml",
    params:
        split_by="tag",
        tag_name="HP",
        required_reference_overlap=["HXB2F:3000-3020"],
        output_format="bam",
        sample_name="toy",
    wrapper:
        f"file:{TEST_ROOT_cigarmath__SPLIT.parent}"


# ---------------------------------------------------------------------------
# Prep rules — convert SAM inputs to BAM
# ---------------------------------------------------------------------------
rule test_split__sort_test_bam:
    input:
        TEST_ROOT_cigarmath__SPLIT / "../../test_data/test.sam"
    output:
        temp(TEST_ROOT_cigarmath__SPLIT / "test_output/test.bam")
    params:
        extra=""
    wrapper:
        f"{WRAPPER_VERSION}/bio/samtools/sort"


rule test_split__sort_toy_bam:
    input:
        TEST_ROOT_cigarmath__SPLIT / "toy_namesorted.sam"
    output:
        temp(TEST_ROOT_cigarmath__SPLIT / "test_output/toy_namesorted.bam")
    params:
        extra="-n"
    wrapper:
        f"{WRAPPER_VERSION}/bio/samtools/sort"
